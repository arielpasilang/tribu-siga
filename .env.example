SANITY_PROJECT_ID=your-project-id
SANITY_DATASET=production

# Viewer-scope token. Required once the dataset is set to private.
# Used by the Gatsby build and by the login function to look up the user.
# sanity.io/manage -> API -> Tokens -> Add API token -> Viewer
SANITY_READ_TOKEN=

# Editor-scope token. Never sent to the browser. Used by scripts/migrate-to-sanity.js,
# scripts/create-user.js, and the create-expedition/create-gallery Netlify Functions.
# sanity.io/manage -> API -> Tokens -> Add API token -> Editor
SANITY_WRITE_TOKEN=

# Long random string used to sign/verify the dashboard login session cookie.
# Must be the same value in Netlify's env vars for both the login function
# and the protect-dashboard edge function. Generate with: openssl rand -hex 32
SESSION_SECRET=
